{
    "name": "typescript_cv_template",
    "version": "1.0.0",
    "description": "a typescript version of cv template",
    "main": "index.js",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/corentinffoucault/typescript_cv_template.git"
    },
    "keywords": [],
    "author": "",
    "license": "MIT",
    "type": "module",
    "scripts": {
        "build": "npx tsc --build",
        "build-tests": "tsc -p tsconfig.test.json && shx cp -r ./resources ./dist-tests",
        "pretest": "npm run build && npm run build-tests",
        "test": "find dist-tests -type f -name \"*Spec.js\" | xargs node --test",
        "build2": "npx tsc --build tsconfig.json",
        "start": "node dist/index.js"
    },
    "dependencies": {
        "feather-icons": "^4.28.0",
        "micromark": "^2.11.0",
        "striptags": "^3.2.0"
    },
    "homepage": "https://github.com/corentinffoucault/typescript_cv_template#readme",
    "devDependencies": {
        "@types/chai": "^4.3.5",
        "@types/feather-icons": "^4.29.4",
        "@types/mocha": "^10.0.10",
        "@types/node": "^24.2.1",
        "chai": "^5.2.1",
        "mocha": "^11.7.1",
        "shx": "^0.4.0"
    }
}